# Firebase Admin (backend)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE\n-----END PRIVATE KEY-----\n"

# Firebase Web API Key (usada pelo login do admin no frontend)
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_GOOGLE_CLIENT_ID=seu-google-oauth-client-id
FIREBASE_WEB_AUTH_DOMAIN=seu-projeto.firebaseapp.com
FIREBASE_WEB_PROJECT_ID=seu-projeto
FIREBASE_WEB_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx

# Opcional: documento usado para guardar o store no Firestore
FIREBASE_STORE_COLLECTION=barbeariaApp
FIREBASE_STORE_DOC=store
